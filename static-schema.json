

{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/schemas/flowchart-ir/v1",
    "title": "Intermediate Representation for a Static Flowchart",
    "description": "IR for making flowcharts accessible to visually impaired persons",
    "type": "object",
    "required": ["id", "elements", "structure", "state", "semantics", "provenance"],
    "additionalProperties": false,

    "properties": {
      "id": {
        "type": "string",
        "format": "date-time",
        "description": "Unique identifier for this flowchart"
      },

      "elements": {
        "type": "object",
        "description": "The basic building blocks of a flowchart — vertices and edges",
        "required": ["nodes", "connections"],
        "additionalProperties": false,
        "properties": {

          "nodes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["shape", "text", "id"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "shape": {
                  "type": "string",
                  "enum": [
                    "rectangle",
                    "diamond",
                    "oval",
                    "parallelogram",
                    "circle",
                    "rounded-rectangle", 
			              "triangle",
                    "other"
                  ]
                },
                "text": { "type": ["string", "null"] },
                "position": { "$ref": "#/$defs/position" },
                "visual": { "$ref": "#/$defs/visual_attrs" }
              }
            }
          },

          "connections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "source", "target"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "source": {
                  "type": "string",
                  "description": "ID of the source node"
                },
                "target": {
                  "type": "string",
                  "description": "ID of the target node"
                },
                "direction": {
                  "type": "string",
                  "enum": ["forward", "backward", "bidirectional", "none"],
                  "default": "forward"
                },
                "line_type": {
                  "type": "string",
                  "enum": ["solid", "dashed", "dotted"],
                  "default": "solid"
                },
                "label": { "type": "string" },
                "visual": { "$ref": "#/$defs/visual_attrs" }
              }
            }
          }
        }
      },

      "structure": {
        "type": "object",
        "description": "Organization, complexity management, and cross-graph relationships",
        "additionalProperties": false,
        "properties": {

          "hierarchy": {
            "type": "array",
            "description": "Logical groupings and parent-child relationships",
            "items": {
              "type": "object",
              "required": ["id", "parent", "children"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "parent": {
                  "type": ["string", "null"],
                  "description": "ID of parent group for nesting,  set to null when flat grouping"
                },
                "children": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" },
                  "description": "IDs of nodes or sub-groups belonging to this group"
                }
              }
            }
          }
        }
      },

      "state": {
        "type": "object",
        "description": "The current state of the entire frame",
        "additionalProperties": false,
        "properties": {

          "cross_links": {
            "type": "array",
            "description": "Architectural relationships between flowcharts on the same board",
            "items": {
              "type": "object",
              "required": ["source_flowchart", "target_flowchart", "source_element", "target_element"],
              "additionalProperties": false,
              "properties": {
                "source_flowchart": {
                  "type": "string",
                  "description": "ID of the flowchart with outgoing link"
                },
                "target_flowchart": {
                  "type": "string",
                  "description": "ID of the linked flowchart"
                },
                "source_element": {
                  "type": "string",
                  "description": "ID of element in this flowchart"
                },
                "target_element": {
                  "type": "string",
                  "description": "ID of element in the target flowchart"
                },
                "label": { "type": "string" }
              }
            }
          },


          "compacted": {
            "type": "object",
            "description": "Complexity management through collapsing and summarization",
            "additionalProperties": false,
            "properties": {
              "detail_level": {
                "type": "string",
                "oneOf": [
                  {
                    "const": "full",
                    "description": "All nodes and connections visible"
                  },
                  {
                    "const": "summary",
                    "description": "Collapsed groups shown as single summary nodes"
                  },
                  {
                    "const": "minimal",
                    "description": "Only top-level flow with group summaries"
                  }
                ]
              },
              "collapsed_groups": {
                "type": "array",
                "items": { "type": "string" },
                "description": "IDs of hierarchy groups currently collapsed"
              },
              "summaries": {
                "type": "array",
                "description": "Text summaries for collapsed regions",
                "items": {
                  "type": "object",
                  "required": ["group_id", "summary"],
                  "additionalProperties": false,
                  "properties": {
                    "group_id": { "type": "string" },
                    "summary": { "type": "string" }
                  }
                }
              }
            }
          },

          "board_state": {
            "type": "string",
            "description": "Plain-text description of the current board state"
          }
        }
      },

      "provenance": {
        "type": "object",
        "description": "AI generation metadata and quality signals. Optional — omit when the IR is hand-authored.",
        "required": ["model", "confidence", "visibility_issues", "time_taken"],
        "additionalProperties": false,
        "properties": {
          "model": {
            "type": "string",
            "description": "LLM model identifier used to generate this IR."
          },
          "confidence": {
            "$ref": "#/$defs/confidence_level"
          },
          "visibility_issues": {
            "type": ["string", "null"],
            "description": "Description of visibility problems that may have affected IR accuracy (e.g., glare, occlusion, low resolution). Null when no issues."
          },
          "reasoning_steps": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of agentic reasoning steps executed. Present only in agentic analyses."
          },
          "time_taken": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "description": "Wall-clock time the analysis took to complete, in MM:SS format.",
            "examples": ["01:45", "00:30"]
          }
        }
      },

      "reasoning_process": {
        "type": ["string", "null"],
        "description": "Agentic pipeline's intermediate reasoning trace stored as a raw string. Null when no reasoning steps were recorded, or absent in basic pipeline."
      },

      "semantics": {
        "type": "object",
        "description": "Context on supplementary visual guides to aid semantic understanding",
        "additionalProperties": false,
        "properties": {
            
          "symbols": {
            "type": ["array", "null"],
            "description": "Semantic meaning of shapes and visual conventions, defined once as a lookup table",
            "items": {
              "type": "object",
              "required": ["symbol", "meaning"],
              "additionalProperties": false,
              "properties": {
                "symbol": { "type":"string"},
                "meaning": {
                  "type": "string",
                  "description": "What this symbol represents (e.g., 'diamond' means 'decision point')"
                },
                "applicable_to": {
                  "type": "array",
                  "items": { "type": ["string", "null"] },
                  "description": "IDs of elements using this symbol"
                }
              }
            }
          },

          "annotations": {
            "type": ["array", "null"],
            "description": "Interpretive overlays on elements — highlighting, emphasis, instructor commentary",
            "items": {
              "type": "object",
              "required": ["id", "target", "annotation_type"],
              "additionalProperties": false,
              "properties": {
                "id": { "type": "string" },
                "target": {
                  "type": "string",
                  "description": "ID of the annotated node or connection in the elements group"
                },
                "annotation_type": {
                  "type": "string",
                  "enum": [
		               "container",
			             "separator",
                    "highlight",
                    "circle",
                    "underline",
                    "arrow",
                    "cloud",
                    "strikethrough"
                  ]
                },
                "content": {
                  "type": ["string", "null"],
                  "description": "Text content or note attached to the annotation"
                }
              }
            }
          }
        }
      }
    },
    


    "$defs": {
      "position": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" }
        }
      },
      "visual_attrs": {
        "type": ["object", "null"],
        "description": "Visual properties of nodes and connections",
        "additionalProperties": false,
        "properties": {
          "color": { "type": "string" }
        }
      },
      "confidence_level": {
        "type": "string",
        "enum": ["high", "medium", "low"],
        "description": "Confidence level for analysis accuracy."
      }
    }
  }




